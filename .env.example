# QuantumLabs backend env — copy to `.env` (git-ignored) and fill in.
# api/main.py loads `.env` at import; values already in the environment win.

# Uzak OpenAI-uyumlu LLM endpoint (or. RunPod serverless .../openai/v1).
# URL VE KEY birlikte set ise Session buraya yonlendirilir; biri eksikse
# lokal env-default davranis birebir korunur.
# Model adi opsiyonel override (default: efeacil/qwen3-4b-quantum, case-sensitive).
QUANTUM_POD_BASE_URL=
QUANTUM_POD_API_KEY=
# QUANTUM_POD_MODEL=efeacil/qwen3-4b-quantum

# API guvenlik (opsiyonel): set ise tum route'lar Bearer token / ?key= ister.
# API_KEY=

# CORS: virgulle ayrilmis izinli origin'ler (default: http://localhost:3000).
# ALLOWED_ORIGINS=https://q-labs.dev,https://www.q-labs.dev
